# ══════════════════════════════════════════════
# TENNIS CLUB HALLUIN — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# Ne JAMAIS commiter .env.local sur GitHub
# ══════════════════════════════════════════════

# ── SUPABASE ────────────────────────────────────
# Récupérer sur : https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── RESEND (emails transactionnels) ─────────────
# Récupérer sur : https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── APPLICATION ─────────────────────────────────
NEXT_PUBLIC_APP_URL=https://tch-halluin.fr

# En développement local, remplacer par :
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── CODE D'ACCÈS ────────────────────────────────
# Code de test pour le développement (pas de vérification en dev)
# En production, les codes sont gérés depuis le dashboard admin
NEXT_PUBLIC_DEV_ACCESS_CODE=TCH_TEST_2026

# ── EMAIL CONTACT ────────────────────────────────
# Adresse de réception des messages du formulaire de contact
# Peut aussi être configuré depuis le dashboard admin (table site_config)
CONTACT_EMAIL=contact@tch.fr
